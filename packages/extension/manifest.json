{
  "manifest_version": 3,
  "name": "OpenBrowserMCP",
  "version": "1.0.0",
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "OpenBrowserMCP",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "debugger",
    "tabGroups",
    "tabs",
    "alarms",
    "notifications",
    "downloads",
    "webNavigation",
    "offscreen"
  ],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "js": ["content/accessibility-tree.js"],
      "matches": ["<all_urls>"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "js": ["content/visual-indicator.js"],
      "matches": ["<all_urls>"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
